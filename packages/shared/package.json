{
  "name": "@chimu-sync/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared utilities, types, constants and Zod schemas for Chimu Sync packages.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "devDependencies": {
    "typescript": "~5.6.2",
    "@chimu-sync/typescript-config": "workspace:*"
  }
}
