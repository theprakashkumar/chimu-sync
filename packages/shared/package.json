{
  "name": "@chimu-sync/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared utilities, types, constants and Zod schemas for Chimu Sync packages.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json",
    "dev": "tsc -w -p tsconfig.json & tsc -w -p tsconfig.esm.json & wait",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    }
  },
  "devDependencies": {
    "typescript": "~5.6.2"
  }
}
